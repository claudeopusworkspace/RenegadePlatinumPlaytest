# ROM files (copyrighted)
*.nds

# Emulator state (binary, large, session-specific)
savestates/
snapshots/

# RAM dumps (temporary analysis artifacts)
*.bin

# Generated output files (regenerated on demand)
map_view.txt
nav_view.txt

# DeSmuME MCP subproject (separate repo)
DesmumeMCP/

# Reference decompilation (external repo, ~26k files)
ref/

# ROM extracted data (large, can be re-extracted)
romdata/

# Emulator checkpoints (ring buffer, huge)
checkpoints/

# Auto-grind session logs
logs/

# DeSmuME MCP server logs (rotated)
desmume_mcp.log*

# IPC bridge socket
.desmume_bridge.sock

# Python
__pycache__/
*.pyc

{
  "mcpServers": {
    "melonds": {
      "command": "/workspace/MelonMCP/.venv/bin/python",
      "args": ["-m", "melonds_mcp"],
      "cwd": "/workspace/MelonMCP",
      "env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy",
        "PYTHONPATH": "/workspace/MelonMCP"
      }
    },
    "renegade": {
      "command": "/workspace/MelonMCP/.venv/bin/python",
      "args": ["-m", "renegade_mcp"],
      "cwd": "/workspace/RenegadePlatinumPlaytest",
      "env": {
        "PYTHONPATH": "/workspace/RenegadePlatinumPlaytest:/workspace/MelonMCP"
      }
    }
  }
}
